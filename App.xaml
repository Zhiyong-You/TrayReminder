<Application x:Class="TrayReminder.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>

        <!-- ======================================================= -->
        <!-- Dialog shared brushes                                     -->
        <!-- ======================================================= -->
        <SolidColorBrush x:Key="DialogBg"           Color="#F7F5FF"/>
        <SolidColorBrush x:Key="DialogTitleFg"      Color="#1A1630"/>
        <SolidColorBrush x:Key="DialogLabelFg"      Color="#6B6A8D"/>
        <SolidColorBrush x:Key="DialogAccent"       Color="#7C65D8"/>
        <SolidColorBrush x:Key="DialogAccentHover"  Color="#9070F0"/>
        <SolidColorBrush x:Key="DialogDanger"       Color="#C0392B"/>
        <SolidColorBrush x:Key="DialogInputBg"      Color="#FFFFFF"/>
        <SolidColorBrush x:Key="DialogInputBorder"  Color="#D5D0EC"/>

        <!-- ======================================================= -->
        <!-- Label (TextBlock) style                                   -->
        <!-- ======================================================= -->
        <Style x:Key="DialogLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource DialogLabelFg}"/>
        </Style>

        <!-- ======================================================= -->
        <!-- TextBox style (rounded, focus-aware)                      -->
        <!-- ======================================================= -->
        <Style x:Key="DialogTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background"     Value="{StaticResource DialogInputBg}"/>
            <Setter Property="Foreground"     Value="{StaticResource DialogTitleFg}"/>
            <Setter Property="FontSize"       Value="13"/>
            <Setter Property="Padding"        Value="7,6"/>
            <Setter Property="CaretBrush"     Value="{StaticResource DialogAccent}"/>
            <Setter Property="SelectionBrush" Value="#C5B8F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource DialogInputBorder}"
                                BorderThickness="1"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalScrollBarVisibility="Auto"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{StaticResource DialogAccent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#A89FD8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ======================================================= -->
        <!-- ComboBox style                                            -->
        <!-- ======================================================= -->
        <Style x:Key="DialogComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background"      Value="{StaticResource DialogInputBg}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource DialogInputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Padding"         Value="4,0"/>
        </Style>

        <!-- ======================================================= -->
        <!-- DatePicker style                                          -->
        <!-- ======================================================= -->
        <Style x:Key="DialogDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Background"      Value="{StaticResource DialogInputBg}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource DialogInputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="30"/>
        </Style>

        <!-- ======================================================= -->
        <!-- CheckBox style                                            -->
        <!-- ======================================================= -->
        <Style x:Key="DialogCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource DialogTitleFg}"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ======================================================= -->
        <!-- Primary button (OK / 保存)                               -->
        <!-- ======================================================= -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource DialogAccent}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="22,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource DialogAccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#6050C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ======================================================= -->
        <!-- Secondary button (キャンセル)                            -->
        <!-- ======================================================= -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource DialogAccent}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource DialogInputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="22,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0EEFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E4DEFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ======================================================= -->
        <!-- Danger button (削除)                                     -->
        <!-- ======================================================= -->
        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource DialogDanger}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="22,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
