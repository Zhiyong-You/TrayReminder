<Window x:Class="TrayReminder.Views.ConfirmDeleteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="削除の確認" Height="186" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource DialogBg}">

    <Grid Margin="22,18,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="リマインダーを削除"
                   FontSize="15" FontWeight="SemiBold"
                   Foreground="{StaticResource DialogTitleFg}"/>

        <!-- Message -->
        <TextBlock Grid.Row="2" x:Name="MessageText"
                   FontSize="13" TextWrapping="Wrap"
                   Foreground="{StaticResource DialogLabelFg}"
                   LineHeight="20"/>

        <!-- Buttons: キャンセル left, 削除 right -->
        <!-- キャンセルを先に置き誤操作を防止 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="キャンセル"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,8,0"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
            <Button Content="削除"
                    Style="{StaticResource DangerButtonStyle}"
                    Click="DeleteButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
