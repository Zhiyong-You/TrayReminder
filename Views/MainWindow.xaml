<Window x:Class="TrayReminder.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrayReminder" Height="400" Width="500"
        MinHeight="300" MinWidth="400">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- リマインダー一覧 -->
        <ListView Grid.Row="0"
                  ItemsSource="{Binding Reminders}"
                  Margin="0,0,0,8">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="タイトル"     Width="260" DisplayMemberBinding="{Binding Title}"/>
                    <GridViewColumn Header="通知時刻"     Width="160" DisplayMemberBinding="{Binding RemindAt, StringFormat=yyyy/MM/dd HH:mm}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- ボタンエリア -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="追加" Width="80" Margin="0,0,8,0"
                    Click="AddButton_Click"/>
            <Button Content="保存" Width="80"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>

</Window>
