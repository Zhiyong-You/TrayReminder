<Window x:Class="TrayReminder.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrayReminder" Height="500" Width="740"
        MinHeight="380" MinWidth="580">

    <Window.Resources>
        <!-- ===== Brushes ===== -->
        <SolidColorBrush x:Key="SidebarBg"         Color="#1E1A2E"/>
        <SolidColorBrush x:Key="SidebarText"       Color="#E2DEFF"/>
        <SolidColorBrush x:Key="SidebarSubText"    Color="#7A7490"/>
        <SolidColorBrush x:Key="SidebarDivider"    Color="#2D2647"/>
        <SolidColorBrush x:Key="CardBg"            Color="#252240"/>
        <SolidColorBrush x:Key="CardHoverBg"       Color="#2E2852"/>
        <SolidColorBrush x:Key="CardSelectedBg"    Color="#352F60"/>
        <SolidColorBrush x:Key="CardDisabledText"  Color="#4E4A68"/>
        <SolidColorBrush x:Key="CardDisabledSub"   Color="#3A3655"/>
        <SolidColorBrush x:Key="AccentBrush"       Color="#7C65D8"/>
        <SolidColorBrush x:Key="AccentHoverBrush"  Color="#9070F0"/>
        <SolidColorBrush x:Key="DetailBg"          Color="#F5F3FF"/>
        <SolidColorBrush x:Key="DetailText"        Color="#1A1630"/>
        <SolidColorBrush x:Key="SecondaryText"     Color="#6B6A8D"/>
        <SolidColorBrush x:Key="NoteBg"            Color="#EBE6F8"/>
        <SolidColorBrush x:Key="SnoozeBrush"       Color="#6B6191"/>
        <SolidColorBrush x:Key="DangerBrush"       Color="#C0392B"/>

        <!-- ===== Filter ComboBox Item ===== -->
        <!-- FilterComboBoxStyle より先に宣言（StaticResource 参照のため） -->
        <Style x:Key="FilterComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground"       Value="#C8C3E8"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Padding"          Value="10,6"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E2852"/>
                                <Setter Property="Foreground" Value="#E2DEFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#352F60"/>
                                <Setter Property="Foreground" Value="#E2DEFF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected"    Value="True"/>
                                    <Condition Property="IsHighlighted" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#3E3870"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Filter ComboBox ===== -->
        <Style x:Key="FilterComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground"         Value="#C8C3E8"/>
            <Setter Property="Background"         Value="#252240"/>
            <Setter Property="BorderBrush"        Value="#3D3860"/>
            <Setter Property="BorderThickness"    Value="1"/>
            <Setter Property="FontSize"           Value="11"/>
            <Setter Property="Cursor"             Value="Hand"/>
            <Setter Property="FocusVisualStyle"   Value="{x:Null}"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource FilterComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- メインボタン領域 -->
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="22"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- 選択中アイテム表示 -->
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="9,5,0,5"
                                                      VerticalAlignment="Center"
                                                      IsHitTestVisible="False"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    <!-- ドロップダウン矢印 -->
                                    <Path x:Name="Arrow"
                                          Grid.Column="1"
                                          Data="M 0 0 L 4 4 L 8 0"
                                          Stroke="#7A7490"
                                          StrokeThickness="1.5"
                                          StrokeLineJoin="Round"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            <!-- クリック受付用透明トグルボタン -->
                            <ToggleButton IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                       RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <!-- ドロップダウン Popup -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#252240"
                                        BorderBrush="#3D3860"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd"    Property="Background"  Value="#2E2852"/>
                                <Setter TargetName="Bd"    Property="BorderBrush" Value="#5A4FAA"/>
                                <Setter TargetName="Arrow" Property="Stroke"      Value="#9B8FE8"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd"    Property="BorderBrush" Value="#7C65D8"/>
                                <Setter TargetName="Arrow" Property="Stroke"      Value="#7C65D8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Clear Completed Button ===== -->
        <Style x:Key="ClearCompletedButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource SidebarSubText}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource SidebarDivider}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="0,7"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#8B3A3A"/>
                                <Setter TargetName="Bd" Property="Background"  Value="#2A1515"/>
                                <Setter Property="Foreground" Value="#E57373"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A1C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Add Button ===== -->
        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0,10"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#6050C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Action Button (Edit / Delete) ===== -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ListViewItem (card style) ===== -->
        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Margin"          Value="0,2"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <!-- Card outer border -->
                        <Border x:Name="CardBd"
                                Background="{StaticResource CardBg}"
                                CornerRadius="7"
                                Margin="8,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <!-- Left accent bar column -->
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Accent bar: visible only when selected -->
                                <Border x:Name="AccentBar"
                                        Grid.Column="0"
                                        Background="Transparent"
                                        CornerRadius="7,0,0,7"/>
                                <ContentPresenter Grid.Column="1"
                                                  Margin="10,9,10,9"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBd" Property="Background"
                                        Value="{StaticResource CardHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CardBd" Property="Background"
                                        Value="{StaticResource CardSelectedBg}"/>
                                <Setter TargetName="AccentBar" Property="Background"
                                        Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================================================ -->
        <!-- Left Sidebar                                      -->
        <!-- ================================================ -->
        <Grid Grid.Column="0" Background="{StaticResource SidebarBg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- App title header -->
            <Border Grid.Row="0" Padding="16,16,16,12"
                    BorderBrush="{StaticResource SidebarDivider}" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="TrayReminder"
                               Foreground="{StaticResource SidebarText}"
                               FontSize="16" FontWeight="Bold"/>
                    <TextBlock x:Name="ReminderCountText"
                               Foreground="{StaticResource SidebarSubText}"
                               FontSize="11" Margin="0,3,0,0"/>
                    <ComboBox x:Name="FilterComboBox"
                              Style="{StaticResource FilterComboBoxStyle}"
                              Margin="0,8,0,0"
                              SelectionChanged="FilterComboBox_SelectionChanged">
                        <ComboBoxItem Content="すべて"     IsSelected="True"/>
                        <ComboBoxItem Content="有効のみ"/>
                        <ComboBoxItem Content="未完了のみ"/>
                        <ComboBoxItem Content="期限超過のみ"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Reminder list -->
            <ListView Grid.Row="1" x:Name="ReminderList"
                      ItemsSource="{Binding Reminders}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0,4,0,4"
                      SelectionChanged="ReminderList_SelectionChanged"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <!-- x:Name で Opacity 制御するためルート Grid に名前を付ける -->
                        <Grid x:Name="ContentGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Title -->
                            <TextBlock x:Name="TitleText"
                                       Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Title}"
                                       Foreground="{StaticResource SidebarText}"
                                       FontSize="13"
                                       TextTrimming="CharacterEllipsis"/>

                            <!-- 状態インジケーター: 通常/無効=ドット、完了=✓ -->
                            <Grid Grid.Row="0" Grid.Column="1"
                                  Width="14" VerticalAlignment="Center"
                                  Margin="6,0,2,0">
                                <Ellipse x:Name="StatusDot"
                                         Width="6" Height="6"
                                         Fill="#4CAF50"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                                <TextBlock x:Name="CompletedMark"
                                           Text="✓" FontSize="9"
                                           Foreground="#7C65D8"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Grid>

                            <!-- Date / time -->
                            <TextBlock x:Name="TimeText"
                                       Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                       Text="{Binding ReminderTime, StringFormat=MM/dd HH:mm}"
                                       Foreground="{StaticResource SidebarSubText}"
                                       FontSize="11"
                                       Margin="0,3,0,0"/>
                        </Grid>

                        <DataTemplate.Triggers>
                            <!-- 無効: テキスト・ドットをミュート -->
                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                <Setter TargetName="TitleText" Property="Foreground"
                                        Value="{StaticResource CardDisabledText}"/>
                                <Setter TargetName="TimeText"  Property="Foreground"
                                        Value="{StaticResource CardDisabledSub}"/>
                                <Setter TargetName="StatusDot" Property="Fill"
                                        Value="#3A3555"/>
                            </DataTrigger>
                            <!-- 完了: 後に宣言するため無効トリガーより優先される -->
                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                <Setter TargetName="ContentGrid"   Property="Opacity"         Value="0.70"/>
                                <Setter TargetName="TitleText"     Property="Foreground"      Value="#5A5678"/>
                                <Setter TargetName="TitleText"     Property="TextDecorations" Value="{x:Static TextDecorations.Strikethrough}"/>
                                <Setter TargetName="TimeText"      Property="Foreground"      Value="#3D3A58"/>
                                <Setter TargetName="StatusDot"     Property="Visibility"      Value="Collapsed"/>
                                <Setter TargetName="CompletedMark" Property="Visibility"      Value="Visible"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Bottom buttons -->
            <StackPanel Grid.Row="2" Margin="12,8,12,12">
                <Button Content="＋  リマインダーを追加"
                        Margin="0,0,0,6"
                        Style="{StaticResource AddButtonStyle}"
                        Click="AddButton_Click"/>
                <Button Content="完了済みを削除"
                        Style="{StaticResource ClearCompletedButtonStyle}"
                        Click="ClearCompletedButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- ================================================ -->
        <!-- Right Detail Area                                 -->
        <!-- ================================================ -->
        <Grid Grid.Column="1" Background="{StaticResource DetailBg}">

            <!-- Placeholder: nothing selected -->
            <StackPanel x:Name="NoSelectionPanel"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="⊙"
                           FontSize="42" Foreground="#C4BFDE"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="リマインダーを選択すると"
                           Foreground="{StaticResource SecondaryText}"
                           FontSize="13" HorizontalAlignment="Center"
                           Margin="0,12,0,2"/>
                <TextBlock Text="ここに詳細が表示されます"
                           Foreground="{StaticResource SecondaryText}"
                           FontSize="13" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Detail panel (shown when item is selected) -->
            <ScrollViewer x:Name="DetailPanel"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,20,24,20">

                    <!-- ── Header: title + status badge ── -->
                    <TextBlock x:Name="DetailTitle"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource DetailText}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"/>

                    <Border x:Name="DetailEnabledBadge"
                            CornerRadius="10" Padding="9,3"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,18">
                        <TextBlock x:Name="DetailEnabled"
                                   FontSize="11" FontWeight="SemiBold"/>
                    </Border>

                    <!-- ── Meta info card ── -->
                    <Border Background="White" CornerRadius="8"
                            Padding="14,12" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="68"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="通知日時"
                                       Foreground="{StaticResource SecondaryText}"
                                       FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       x:Name="DetailTime"
                                       Foreground="{StaticResource DetailText}"
                                       FontSize="13" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="繰り返し"
                                       Foreground="{StaticResource SecondaryText}"
                                       FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       x:Name="DetailRepeat"
                                       Foreground="{StaticResource DetailText}"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- ── Notes ── -->
                    <TextBlock Text="メモ"
                               Foreground="{StaticResource SecondaryText}"
                               FontSize="12" Margin="0,0,0,5"/>
                    <Border Background="{StaticResource NoteBg}"
                            CornerRadius="8" Padding="12,10" Margin="0,0,0,22">
                        <TextBlock x:Name="DetailDescription"
                                   Foreground="{StaticResource DetailText}"
                                   FontSize="13" TextWrapping="Wrap"
                                   LineHeight="20"/>
                    </Border>

                    <!-- ── Action buttons: [編集] [スヌーズ]  ··  [削除] ── -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="編集"
                                Style="{StaticResource ActionButtonStyle}"
                                Background="{StaticResource AccentBrush}"
                                Foreground="White"
                                Click="EditButton_Click"/>

                        <Button Grid.Column="2"
                                Content="10分スヌーズ"
                                Style="{StaticResource ActionButtonStyle}"
                                Background="{StaticResource SnoozeBrush}"
                                Foreground="White"
                                Click="SnoozeButton_Click"/>

                        <Button Grid.Column="4"
                                Content="削除"
                                Style="{StaticResource ActionButtonStyle}"
                                Background="{StaticResource DangerBrush}"
                                Foreground="White"
                                Click="DeleteButton_Click"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
