<Window x:Class="TrayReminder.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrayReminder" Height="400" Width="560"
        MinHeight="300" MinWidth="420">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListView Grid.Row="0" x:Name="ReminderList"
                  ItemsSource="{Binding Reminders}"
                  Margin="0,0,0,8">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="タイトル"  Width="220" DisplayMemberBinding="{Binding Title}"/>
                    <GridViewColumn Header="通知日時"  Width="140" DisplayMemberBinding="{Binding ReminderTime, StringFormat=yyyy/MM/dd HH:mm}"/>
                    <GridViewColumn Header="有効" Width="50">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                          IsHitTestVisible="False" Focusable="False"
                                          HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="追加" Width="80" Margin="0,0,8,0" Click="AddButton_Click"/>
            <Button Content="編集" Width="80" Margin="0,0,8,0" Click="EditButton_Click"/>
            <Button Content="削除" Width="80" Click="DeleteButton_Click"/>
        </StackPanel>
    </Grid>

</Window>
