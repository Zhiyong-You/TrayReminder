<Window x:Class="TrayReminder.Views.QuickAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新規リマインダー"
        Width="340" Height="280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="タイトル" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TitleBox" Margin="0,4"/>

        <Label Grid.Row="1" Grid.Column="0" Content="説明" VerticalAlignment="Top" Margin="0,4,0,0"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="DescriptionBox"
                 Height="48" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,4"/>

        <Label Grid.Row="2" Grid.Column="0" Content="日付" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="2" Grid.Column="1" x:Name="ReminderDatePicker" Margin="0,4"/>

        <Label Grid.Row="3" Grid.Column="0" Content="時刻" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="ReminderTimeBox" Margin="0,4"/>

        <Label Grid.Row="4" Grid.Column="0" Content="繰り返し" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="4" Grid.Column="1" x:Name="RepeatTypeBox" Margin="0,4"/>

        <CheckBox Grid.Row="5" Grid.Column="1" x:Name="IsEnabledCheck"
                  Content="有効" Margin="0,6" IsChecked="True"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="保存" Width="80" Margin="0,0,8,0"
                    Click="SaveButton_Click" IsDefault="True"/>
            <Button Content="キャンセル" Width="80"
                    Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
