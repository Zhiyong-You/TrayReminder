<Window x:Class="TrayReminder.Views.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="リマインダー通知"
        Width="340" Height="272"
        WindowStartupLocation="Manual"
        Topmost="True"
        ResizeMode="NoResize"
        Background="{StaticResource DialogBg}"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <DockPanel>

        <!-- 上部アクセントストライプ -->
        <Border DockPanel.Dock="Top"
                Height="4"
                Background="{StaticResource DialogAccent}"/>

        <DockPanel Margin="20,14,20,18" LastChildFill="True">

            <!-- ── ボタン（先に宣言して下部固定） ── -->
            <StackPanel DockPanel.Dock="Bottom">

                <!-- スヌーズ行 -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,8">
                    <Button Content="5分後"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="14,6" FontSize="12"
                            Margin="0,0,8,0"
                            Click="Snooze5Button_Click"/>
                    <Button Content="10分後"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="14,6" FontSize="12"
                            Click="Snooze10Button_Click"/>
                </StackPanel>

                <!-- アクション行 -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="閉じる"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="16,7"
                            Margin="0,0,8,0"
                            Click="CloseButton_Click"/>
                    <Button Content="完了"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="20,7"
                            Click="CompleteButton_Click"/>
                </StackPanel>

            </StackPanel>

            <!-- ── コンテンツエリア ── -->
            <StackPanel>

                <!-- タイトル -->
                <TextBlock x:Name="TitleText"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource DialogTitleFg}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"/>

                <!-- 通知日時バッジ + 日時テキスト -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <Border Background="{StaticResource DialogAccent}"
                            CornerRadius="3" Padding="6,2"
                            Margin="0,0,8,0" VerticalAlignment="Center">
                        <TextBlock Text="通知日時"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="White"/>
                    </Border>
                    <TextBlock x:Name="TimeText"
                               FontSize="12"
                               Foreground="{StaticResource DialogLabelFg}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- メモボックス -->
                <Border Background="#EBE6F8"
                        CornerRadius="7"
                        Padding="11,9"
                        MinHeight="50">
                    <TextBlock x:Name="DescriptionText"
                               FontSize="12"
                               Foreground="{StaticResource DialogTitleFg}"
                               TextWrapping="Wrap"
                               LineHeight="18"/>
                </Border>

            </StackPanel>
        </DockPanel>
    </DockPanel>
</Window>
