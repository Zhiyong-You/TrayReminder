<Window x:Class="TrayReminder.Views.AddEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="リマインダー" Height="470" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource DialogBg}">

    <!--
        DockPanel を使用:
        ボタンを Dock="Bottom" で先に宣言 → 常に下部に固定
        フィールド StackPanel が残りを埋める
    -->
    <DockPanel Margin="22,18,22,18" LastChildFill="True">

        <!-- ── Buttons (先に宣言することで下部固定) ── -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="キャンセル"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click" IsCancel="True"/>
            <Button Content="OK"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OkButton_Click" IsDefault="True"/>
        </StackPanel>

        <!-- ── Fields ── -->
        <StackPanel>

            <!-- Dialog header -->
            <TextBlock x:Name="DialogTitleText"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource DialogTitleFg}"
                       Margin="0,0,0,16"/>

            <!-- タイトル -->
            <TextBlock Text="タイトル" Style="{StaticResource DialogLabelStyle}"/>
            <TextBox x:Name="TitleBox"
                     Style="{StaticResource DialogTextBoxStyle}"
                     Margin="0,4,0,12"/>

            <!-- メモ -->
            <TextBlock Text="メモ" Style="{StaticResource DialogLabelStyle}"/>
            <TextBox x:Name="DescriptionBox"
                     Style="{StaticResource DialogTextBoxStyle}"
                     Height="58" TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalContentAlignment="Top"
                     Margin="0,4,0,12"/>

            <!-- 通知日時 -->
            <TextBlock Text="通知日時" Style="{StaticResource DialogLabelStyle}"/>
            <Grid Margin="0,4,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="104"/>
                </Grid.ColumnDefinitions>
                <DatePicker Grid.Column="0" x:Name="ReminderDatePicker"
                            Style="{StaticResource DialogDatePickerStyle}"/>
                <ComboBox Grid.Column="2" x:Name="ReminderTimeBox"
                          Style="{StaticResource DialogComboBoxStyle}"/>
            </Grid>

            <!-- 繰り返し -->
            <TextBlock Text="繰り返し" Style="{StaticResource DialogLabelStyle}"/>
            <ComboBox x:Name="RepeatTypeBox"
                      Style="{StaticResource DialogComboBoxStyle}"
                      Margin="0,4,0,12"/>

            <!-- 有効 -->
            <CheckBox x:Name="IsEnabledCheck" Content="有効" IsChecked="True"
                      Style="{StaticResource DialogCheckBoxStyle}"/>
        </StackPanel>

    </DockPanel>
</Window>
