<Window x:Class="TrayReminder.Views.AddEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="リマインダー" Height="300" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="タイトル" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TitleBox" Margin="0,4"/>

        <Label Grid.Row="1" Grid.Column="0" Content="メモ" VerticalAlignment="Top" Margin="0,6,0,0"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="DescriptionBox"
                 Height="56" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,4"/>

        <Label Grid.Row="2" Grid.Column="0" Content="通知日時" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,4">
            <DatePicker x:Name="ReminderDatePicker" Width="140" Margin="0,0,6,0"/>
            <ComboBox x:Name="ReminderTimeBox" Width="80"/>
        </StackPanel>

        <Label Grid.Row="3" Grid.Column="0" Content="繰り返し" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="3" Grid.Column="1" x:Name="RepeatTypeBox" Margin="0,4"/>

        <CheckBox Grid.Row="4" Grid.Column="1" x:Name="IsEnabledCheck"
                  Content="有効" Margin="0,8" IsChecked="True"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,8,0"
                    Click="OkButton_Click" IsDefault="True"/>
            <Button Content="キャンセル" Width="80"
                    Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
